meta {
  name: Create Flag
  type: http
  seq: 2
}

post {
  url: {{base_url}}/flags/
  body: json
  auth: none
}

body:json {
  {
    "project_id": "{{project_id}}",
    "key": "new-feature",
    "name": "New Feature Flag",
    "description": "Enables the new experimental feature",
    "type": "boolean"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("flag_id", res.body.id);
  }
}
