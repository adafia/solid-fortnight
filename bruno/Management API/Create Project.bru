meta {
  name: Create Project
  type: http
  seq: 1
}

post {
  url: {{base_url}}/projects/
  body: json
  auth: none
}

body:json {
  {
    "name": "My Project",
    "description": "A demo project"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("project_id", res.body.id);
  }
}
