meta {
  name: Upsert Flag Environment
  type: http
  seq: 9
}

put {
  url: {{base_url}}/flags/{{flag_id}}/environments/{{env_id}}
  body: json
  auth: none
}

body:json {
  {
    "enabled": true,
    "rules": []
  }
}

script:post-response {
  if (res.status === 200) {
    bru.setVar("flag_env_id", res.body.id);
  }
}
